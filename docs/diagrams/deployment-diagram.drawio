          <mxGeometry x="280" y="170" width="250" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="static" value="&lt;b&gt;Static Files&lt;/b&gt;&lt;br&gt;Vue SPA Build&lt;br&gt;/usr/share/nginx/html/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="230" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="port80" value="Port 80 ← :8080" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="310" width="120" height="20" as="geometry"/>
