<mxfile host="app.diagrams.net" modified="2026-03-18" type="device">
  <diagram name="Deployment Diagram" id="deploy1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;Диаграмма развёртывания (Deployment)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="30" as="geometry"/>
        </mxCell>
        <!-- Server Node -->
        <mxCell id="server" value="&lt;b&gt;Production Server&lt;/b&gt;" style="shape=mxgraph.sysml.package;html=1;overflow=fill;fillColor=#f5f5f5;strokeColor=#333333;verticalAlign=top;fontSize=14;tabWidth=200;tabHeight=30;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="700" height="550" as="geometry"/>
        </mxCell>
        <!-- Docker Compose -->
        <mxCell id="docker" value="&lt;b&gt;Docker Compose&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=13;arcSize=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="120" width="620" height="470" as="geometry"/>
        </mxCell>
        <!-- Nginx -->
