          <mxGeometry x="580" y="170" width="240" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="services" value="&lt;b&gt;Services&lt;/b&gt;&lt;br&gt;Auth | Reports | Validation&lt;br&gt;Templates | Analytics | Admin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="230" width="200" height="60" as="geometry"/>
        </mxCell>
        <!-- Arrow nginx -> spring -->
        <mxCell id="proxy" value="/api/* proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="nginx" target="spring" parent="1">
