        <mxCell id="etu_sys" value="&lt;b&gt;ETU System&lt;/b&gt;&lt;br&gt;(внешняя)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;dashed=1;" vertex="1" parent="1">
